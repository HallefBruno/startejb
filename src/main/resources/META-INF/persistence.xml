<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://w3.org" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://jcp.org">
  <persistence-unit name="startejbPU" transaction-type="JTA">
    <jta-data-source>java:jboss/datasources/startejb</jta-data-source>
    <properties>
      <property name="hibernate.hbm2ddl.auto" value="update"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
    </properties>
  </persistence-unit>
</persistence>
